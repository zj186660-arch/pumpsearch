# 复制为 `.env.local`（勿提交密钥）

# --- Bing Web Search v7 ---
BING_SEARCH_KEY=
# BING_MARKET=en-US

# --- SerpAPI：多引擎 + 分页（显著增加结果量）---
SERPAPI_KEY=
# 逗号分隔，默认同时跑 Bing 与 Google 网页结果
SERPAPI_ENGINES=bing,google
# 兼容旧单引擎变量（仅当未设置 SERPAPI_ENGINES 时生效）
# SERPAPI_ENGINE=bing
# 每引擎请求页数（每页 SERPAPI_NUM 条）
SERPAPI_PAGES_PER_ENGINE=3
# 每页条数（1–100，Google 引擎常见上限依账户而定）
SERPAPI_NUM=20

# --- Google 可编程搜索（CSE）---
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
# CSE 分页次数（每页 10 条，1–10）
PUMPSEARCH_CSE_PAGES=5

# --- 仅 Google CSE 请求是否走 HTTP 代理（SerpAPI 直连 serpapi.com，不经此配置）---
# GOOGLE_FETCH_PROXY=http://127.0.0.1:7890
# 设为 false 则强制直连 Google API（解决代理端口未开 ECONNREFUSED）
# GOOGLE_USE_PROXY=true

# --- 多源顺序（默认先 SerpAPI 多引擎，再 Google CSE，再 Azure Bing）---
SEARCH_FALLBACK_ORDER=serpapi,google,bing,demo

# PUMPSEARCH_QUERY_SUFFIX=...
# OPENAI_API_KEY=
# OPENAI_REFINE_MAX=24
PUMPSEARCH_CACHE_TTL_MS=3600000
# 单次会话内多组检索式（扩大独立域名覆盖；受 API 配额与下方上限约束）
# PUMPSEARCH_QUERY_EXPAND_MAX=28
# 合并去重后的原始站点条数上限（达到后不再跑后续检索式）
# PUMPSEARCH_MAX_RAW_RESULTS=4000
# 不写 data/search-corpus.jsonl（关系图谱语料）
# PUMPSEARCH_SKIP_CORPUS=false

# PUMPSEARCH_APPEND_DEMO=true
# PUMPSEARCH_SKIP_NETWORK=false
# PUMPSEARCH_FETCH_TIMEOUT_MS=25000

# --- Resend（一键发信 ESP）---
# https://resend.com — 需在控制台验证发信域名后，from 使用该域名下地址
# RESEND_API_KEY=
# EMAIL_FROM=onboarding@resend.dev
